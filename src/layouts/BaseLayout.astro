---
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/source-serif-4/400.css';
import '@fontsource/source-serif-4/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@styles/global.css';
import Header from '@components/ui/Header.astro';
import Footer from '@components/ui/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Documenting how dependency changes break digital artworks.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Net Art Extinction Timeline</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta property="og:title" content={`${title} — Net Art Extinction Timeline`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const pref = stored || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', pref);
    })();
  </script>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <script is:inline>
    function wrapHeadingChars() {
      const headings = document.querySelectorAll('main h1, main h2, .page-header h1');
      headings.forEach(h => {
        if (h.closest('.logo') || h.querySelector('.g-ch')) return;
        const walker = document.createTreeWalker(h, NodeFilter.SHOW_TEXT);
        var textNodes = [];
        var node;
        while (node = walker.nextNode()) {
          textNodes.push({ node: node, text: node.textContent || '' });
        }
        textNodes.forEach(({ node, text }) => {
          const frag = document.createDocumentFragment();
          for (let i = 0; i < text.length; i++) {
            const ch = text[i];
            if (/\s/.test(ch)) {
              frag.appendChild(document.createTextNode(ch));
            } else {
              const span = document.createElement('span');
              span.textContent = ch;
              span.className = 'g-ch';
              frag.appendChild(span);
            }
          }
          node.parentNode?.replaceChild(frag, node);
        });
      });
    }

    const glitchClasses = ['glitch-1', 'glitch-2', 'glitch-3', 'glitch-4'];

    function cycleGlitch() {
      // Clear all
      document.querySelectorAll('.g-ch').forEach(function(el) {
        glitchClasses.forEach(c => el.classList.remove(c));
      });

      // Pick chars proportional to heading length
      const headings = document.querySelectorAll('main h1, main h2, .page-header h1');
      headings.forEach(h => {
        if (h.closest('.logo')) return;
        var chars = h.querySelectorAll('.g-ch');
        if (chars.length < 4) return;

        // ~1 per 5 chars, min 2, max 6
        var count = Math.min(6, Math.max(2, Math.floor(chars.length / 5)));
        var used = new Set();

        for (var i = 0; i < count; i++) {
          var idx;
          do { idx = Math.floor(Math.random() * chars.length); } while (used.has(idx));
          used.add(idx);
          var cls = glitchClasses[Math.floor(Math.random() * glitchClasses.length)];
          chars[idx].classList.add(cls);
        }
      });
    }

    function scheduleGlitch() {
      var delay = 8000 + Math.random() * 7000;
      setTimeout(function() {
        cycleGlitch();
        scheduleGlitch();
      }, delay);
    }

    function initGlitch() {
      wrapHeadingChars();
      cycleGlitch();
      scheduleGlitch();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGlitch);
    } else {
      initGlitch();
    }
  </script>
</body>
</html>

<style>
  main {
    min-height: calc(100vh - 8rem);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }
</style>

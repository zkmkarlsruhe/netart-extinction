---
import BaseLayout from '@layouts/BaseLayout.astro';
import AiBadge from '@components/ui/AiBadge.astro';
import { getCollection } from 'astro:content';

const artworks = await getCollection('artworks');
const sorted = artworks.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Group by first letter
const grouped = new Map<string, typeof artworks>();
for (const art of sorted) {
  const letter = art.data.title[0].toUpperCase().match(/[A-Z]/) ? art.data.title[0].toUpperCase() : '#';
  if (!grouped.has(letter)) grouped.set(letter, []);
  grouped.get(letter)!.push(art);
}
---

<BaseLayout title="Artworks" description="Index of digital artworks affected by extinction events.">
  <div class="container">
    <header class="page-header">
      <h1>Artworks</h1>
      <p class="subtitle">{artworks.length} digital artworks catalogued</p>
      <a href="https://github.com/zkmkarlsruhe/netart-extinction/issues/new/choose" class="cta">+ Add your artwork</a>
    </header>

    <div class="letter-nav">
      {[...grouped.keys()].map(letter => (
        <a href={`#${letter}`} class="letter-link">{letter}</a>
      ))}
    </div>

    <div class="artwork-index">
      {[...grouped.entries()].map(([letter, arts]) => (
        <section id={letter}>
          <h2 class="letter-heading">{letter}</h2>
          <div class="artwork-list">
            {arts.map(art => (
              <a href={`/artworks/${art.id}`} class="artwork-row">
                <span class="artwork-title">
                  {art.data.title}
                  {art.data.ai_generated && <AiBadge linked={false} />}
                </span>
                <span class="artwork-artist">{art.data.artist}</span>
                {art.data.year && <span class="artwork-year">{art.data.year}</span>}
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <div class="bottom-cta">
      <p>Know an artwork affected by a dependency change?</p>
      <a href="https://github.com/zkmkarlsruhe/netart-extinction/issues/new/choose" class="cta">+ Add your artwork</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-lg);
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.0625rem;
    margin-top: var(--space-xs);
  }

  .cta {
    display: inline-block;
    margin-top: var(--space-md);
    padding: 0.375rem 1rem;
    border: 1px solid var(--accent);
    border-radius: 6px;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .cta:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .bottom-cta {
    text-align: center;
    padding: var(--space-2xl) 0 var(--space-xl);
    color: var(--text-muted);
  }

  .letter-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
    position: sticky;
    top: 3.5rem;
    background: var(--bg);
    z-index: 10;
    padding-top: var(--space-sm);
  }

  .letter-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .letter-link:hover {
    background: var(--surface);
    color: var(--accent);
  }

  .letter-heading {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
    color: var(--accent);
  }

  section {
    margin-bottom: var(--space-xl);
  }

  .artwork-list {
    display: grid;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    max-width: 100%;
  }

  .artwork-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--surface);
    text-decoration: none;
    color: var(--text);
    transition: background 0.1s;
    min-width: 0;
    overflow: hidden;
  }

  .artwork-row:hover {
    background: var(--bg);
  }

  .artwork-title {
    font-weight: 500;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .artwork-artist {
    color: var(--text-muted);
    font-size: 0.8125rem;
    flex-shrink: 0;
    max-width: 12rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .artwork-year {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .artwork-row {
      flex-wrap: wrap;
      gap: var(--space-xs);
    }

    .artwork-title {
      width: 100%;
      white-space: normal;
    }

    .artwork-artist {
      max-width: none;
    }

    .letter-link {
      width: 1.75rem;
      height: 1.75rem;
      font-size: 0.75rem;
    }
  }
</style>

---
import EventTypeLabel from './EventTypeLabel.astro';
import SeverityBadge from './SeverityBadge.astro';
import AiBadge from './AiBadge.astro';
import { parseFlexibleDate, formatDate } from '@lib/dates';

interface Props {
  id: string;
  title: string;
  date: string;
  dependency: string;
  event_type: string;
  severity?: 'total' | 'major' | 'minor';
  summary: string;
  artworkCount?: number;
  ai_generated?: boolean;
  wikipedia?: string;
}

const { id, title, date, dependency, event_type, severity, summary, artworkCount, ai_generated, wikipedia } = Astro.props;
const parsed = parseFlexibleDate(date);
const displayDate = formatDate(parsed);
---

<div class="event-card">
  <div class="card-header">
    <time datetime={parsed.raw}>{displayDate}</time>
    <EventTypeLabel type={event_type} />
    {severity && <SeverityBadge severity={severity} />}
    {ai_generated && <AiBadge />}
    {wikipedia && <a href={wikipedia} target="_blank" rel="noopener" class="wiki-badge" title="Wikipedia">W</a>}
  </div>
  <h3><a href={`/events/${id}`} class="card-link">{title}</a></h3>
  <p class="dependency">{dependency}</p>
  <p class="summary">{summary}</p>
  {artworkCount != null && artworkCount > 0 && (
    <p class="artwork-count">{artworkCount} artwork{artworkCount !== 1 ? 's' : ''} affected</p>
  )}
</div>

<style>
  .event-card {
    position: relative;
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .event-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .card-link {
    text-decoration: none;
    color: inherit;
  }

  .card-link::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
  }

  .card-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  time {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-xs);
  }

  .dependency {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    margin-bottom: var(--space-sm);
    overflow-wrap: break-word;
  }

  .summary {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .artwork-count {
    margin-top: var(--space-sm);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--severity-total);
  }

  .wiki-badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.625rem;
    font-weight: 700;
    font-family: var(--font-serif);
    text-decoration: none;
    line-height: 1;
  }

  .wiki-badge:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
